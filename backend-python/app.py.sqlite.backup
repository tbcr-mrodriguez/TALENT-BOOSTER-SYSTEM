# ENDPOINTS PARA ENTREVISTAS DASHBOARD
# ========================================

@app.route("/api/entrevistas/todas", methods=["GET"])
def obtener_todas_entrevistas():
    """Obtiene todas las entrevistas con información de candidatos"""
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        # Consulta para obtener entrevistas con datos de candidatos y plantillas
        cursor.execute('''
            SELECT 
                e.id,
                e.candidato_id,
                e.fecha_inicio,
                e.fecha_fin,
                e.estado,
                e.puntuacion_global,
                e.analisis_ia,
                c.nombre as candidato_nombre,
                c.profesion as candidato_profesion,
                p.nombre as plantilla_nombre,
                p.puesto,
                (SELECT COUNT(*) FROM respuestas_entrevista WHERE entrevista_id = e.id) as total_respuestas,
                (SELECT SUM(tiempo_respuesta) FROM respuestas_entrevista WHERE entrevista_id = e.id) as duracion_total
            FROM entrevistas e
            LEFT JOIN candidates c ON e.candidato_id = c.id
            LEFT JOIN plantillas_entrevista p ON e.plantilla_id = p.id
            ORDER BY e.fecha_inicio DESC
        ''')
        
        entrevistas = []
        for row in cursor.fetchall():
            # Parsear análisis si existe
            analisis = None
            if row[6]:
                try:
                    analisis = json.loads(row[6])
                except:
                    analisis = None
            
            entrevistas.append({
                "id": row[0],
                "candidato_id": row[1],
                "fecha_inicio": row[2],
                "fecha_fin": row[3],
                "estado": row[4],
                "puntuacion_global": row[5],
                "analisis_ia": analisis,
                "candidato_nombre": row[7],
                "candidato_profesion": row[8],
                "plantilla": row[9],
                "puesto": row[10],
                "total_respuestas": row[11],
                "duracion": row[12]
            })
        
        conn.close()
        return jsonify({"success": True, "entrevistas": entrevistas})
        
    except Exception as e:
        print(f"❌ Error en obtener_todas_entrevistas: {e}")
        return jsonify({"success": False, "error": str(e)}), 500


@app.route("/api/entrevista/reporte-completo/<int:entrevista_id>", methods=["GET"])
def reporte_entrevista_completo(entrevista_id):
    """Obtiene reporte completo de una entrevista con respuestas"""
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        # 1. Obtener información de la entrevista
        cursor.execute('''
            SELECT 
                e.id,
                e.candidato_id,
                e.fecha_inicio,
                e.fecha_fin,
                e.estado,
                e.puntuacion_global,
                e.analisis_ia,
                e.transcripcion_completa,
                c.nombre as candidato_nombre,
                c.profesion as candidato_profesion,
                c.raw_data,
                p.nombre as plantilla_nombre,
                p.puesto
            FROM entrevistas e
            LEFT JOIN candidates c ON e.candidato_id = c.id
            LEFT JOIN plantillas_entrevista p ON e.plantilla_id = p.id
            WHERE e.id = ?
        ''', (entrevista_id,))
        
        row = cursor.fetchone()
        if not row:
            conn.close()
            return jsonify({"success": False, "error": "Entrevista no encontrada"}), 404
        
        # 2. Obtener respuestas
        cursor.execute('''
            SELECT 
                pregunta_texto,
                respuesta_texto,
                tiempo_respuesta,
                respuesta_video_path,
                analisis_pregunta,
                puntuacion_pregunta
            FROM respuestas_entrevista
            WHERE entrevista_id = ?
            ORDER BY id
        ''', (entrevista_id,))
        
        respuestas = []
        for r in cursor.fetchall():
            respuestas.append({
                "pregunta": r[0],
                "respuesta": r[1],
                "tiempo": r[2],
                "video_url": f"/api/entrevista/video/{r[3]}" if r[3] else None,
                "analisis": json.loads(r[4]) if r[4] else None,
                "puntuacion": r[5]
            })
        
        conn.close()
        
        # 3. Parsear análisis
        analisis = None
        if row[6]:
            try:
                analisis = json.loads(row[6])
            except:
                analisis = None
        
        # 4. Parsear raw_data del candidato (para fotos si existen)
        candidato_data = None
        if row[10]:
            try:
                candidato_data = json.loads(row[10])
            except:
                candidato_data = None
        
        # 5. Calcular duración total
        duracion = sum(r.get('tiempo', 0) for r in respuestas)
        
        return jsonify({
            "success": True,
            "entrevista": {
                "id": row[0],
                "candidato_id": row[1],
                "fecha": row[2],
                "fecha_fin": row[3],
                "estado": row[4],
                "puntuacion_global": row[5],
                "candidato_nombre": row[8],
                "candidato_profesion": row[9],
                "plantilla": row[11],
                "puesto": row[12],
                "duracion": duracion
            },
            "respuestas": respuestas,
            "analisis": analisis,
            "candidato_data": candidato_data,
            "fotos": []  # Por ahora vacío, puedes extraer de candidato_data si guardas fotos
        })
        
    except Exception as e:
        print(f"❌ Error en reporte_entrevista_completo: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500

@app.route("/api/entrevistas/candidato/<int:candidato_id>", methods=["GET"])
def obtener_entrevistas_por_candidato(candidato_id):
    """Obtiene todas las entrevistas de un candidato específico"""
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        cursor.execute('''
            SELECT 
                e.id,
                e.token_acceso,
                e.fecha_inicio,
                e.fecha_fin,
                e.estado,
                e.puntuacion_global,
                e.enlace_compartido,
                p.nombre as plantilla_nombre,
                p.puesto
            FROM entrevistas e
            JOIN plantillas_entrevista p ON e.plantilla_id = p.id
            WHERE e.candidato_id = ?
            ORDER BY e.fecha_inicio DESC
        ''', (candidato_id,))
        
        entrevistas = []
        for row in cursor.fetchall():
            entrevistas.append({
                "id": row[0],
                "token": row[1],
                "fecha_inicio": row[2],
                "fecha_fin": row[3],
                "estado": row[4],
                "puntuacion": row[5],
                "enlace": row[6],
                "plantilla": row[7],
                "puesto": row[8]
            })
        
        conn.close()
        return jsonify({"success": True, "entrevistas": entrevistas})
        
    except Exception as e:
        return jsonify({"success": False, "error": str(e)}), 500
