@app.route("/api/entrevista/resultados/<int:candidato_id>", methods=["GET"])
def obtener_resultados_entrevista(candidato_id):
    """Obtiene los resultados de las entrevistas de un candidato"""
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        cursor.execute('''
            SELECT e.id, e.fecha_inicio, e.fecha_fin, e.estado, 
                   e.analisis_ia, e.puntuacion_global,
                   p.nombre as plantilla, p.puesto
            FROM entrevistas e
            JOIN plantillas_entrevista p ON e.plantilla_id = p.id
            WHERE e.candidato_id = ?
            ORDER BY e.fecha_inicio DESC
        ''', (candidato_id,))
        
        resultados = []
        for row in cursor.fetchall():
            resultados.append({
                "id": row[0],
                "fecha": row[1],
                "fecha_fin": row[2],
                "estado": row[3],
                "analisis": json.loads(row[4]) if row[4] else None,
                "puntuacion": row[5],
                "plantilla": row[6],
                "puesto": row[7]
            })
        
        conn.close()
        return jsonify({"success": True, "resultados": resultados})
        
    except Exception as e:
        return jsonify({"success": False, "error": str(e)}), 500

@app.route("/api/entrevista/analizar/<int:entrevista_id>", methods=["POST"])
def analizar_entrevista(entrevista_id):
    """Analiza la entrevista con IA"""
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        cursor.execute('''
            SELECT r.pregunta_texto, r.respuesta_texto, r.tiempo_respuesta
            FROM respuestas_entrevista r
            WHERE r.entrevista_id = ?
            ORDER BY r.id
        ''', (entrevista_id,))
        
        respuestas = cursor.fetchall()
        
        transcripcion = ""
        for i, (pregunta, respuesta, tiempo) in enumerate(respuestas):
            transcripcion += f"\nPREGUNTA {i+1}: {pregunta}\n"
            transcripcion += f"RESPUESTA: {respuesta}\n"
            if tiempo:
                transcripcion += f"TIEMPO: {tiempo} segundos\n"
            transcripcion += "-" * 50 + "\n"
        
        prompt = f"""
Eres un headhunter experto con 20 años de experiencia. Analiza esta entrevista:

{transcripcion}

Proporciona un análisis en JSON con:
{{
  "fortalezas": ["lista de fortalezas detectadas"],
  "debilidades": ["lista de áreas de mejora"],
  "impresion_general": "texto con impresión general",
  "recomendacion": "contratar / considerar / no_contratar",
  "puntuacion": número del 1 al 10,
  "preguntas_destacadas": [índices de preguntas donde destacó],
  "preguntas_debiles": [índices de preguntas con dificultad]
}}
"""
        
        response = openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt}],
            temperature=0.3
        )
        
        analisis = safe_json_parse(response.choices[0].message.content)
        
        cursor.execute('''
            UPDATE entrevistas 
            SET analisis_ia = ?, puntuacion_global = ?, estado = 'analizada'
            WHERE id = ?
        ''', (json.dumps(analisis, ensure_ascii=False), 
              analisis.get('puntuacion'), entrevista_id))
        
        conn.commit()
        conn.close()
        
        return jsonify({"success": True, "analisis": analisis})
        
    except Exception as e:
        print(f"❌ Error analizando entrevista: {e}")
        return jsonify({"success": False, "error": str(e)}), 500

