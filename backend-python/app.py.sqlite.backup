def safe_json_parse(text):
    start = text.find("{")
    end = text.rfind("}") + 1
    json_text = text[start:end]
    return json.loads(json_text)

def normalize_lists(data):
    if "interpretacion" in data:
        for campo in ["industrias_secundarias", "habilidades_clave", "fortalezas", "areas_mejora"]:
            if campo in data["interpretacion"]:
                arr = data["interpretacion"][campo]
                if not arr:
                    data["interpretacion"][campo] = []
                else:
                    clean = []
                    for item in arr:
                        if isinstance(item, dict):
                            clean.append(" ".join(str(v) for v in item.values()))
                        else:
                            clean.append(str(item))
                    data["interpretacion"][campo] = clean
        
        if "datos_crudos" in data:
            fields = ["certificaciones", "habilidades_listadas", "herramientas_listadas", "idiomas_listados"]
            for f in fields:
                arr = data["datos_crudos"].get(f)
                if not arr:
                    data["datos_crudos"][f] = []
                else:
                    clean = []
                    for item in arr:
                        if isinstance(item, dict):
                            clean.append(" ".join(str(v) for v in item.values()))
                        else:
                            clean.append(str(item))
                    data["datos_crudos"][f] = clean
    else:
        fields = ["certificaciones", "industrias", "roles", "logros", "habilidades", "herramientas", "idiomas"]
        for f in fields:
            arr = data.get(f)
            if not arr:
                data[f] = []
                continue
            clean = []
            for item in arr:
                if isinstance(item, dict):
                    clean.append(" ".join(str(v) for v in item.values()))
                else:
                    clean.append(str(item))
            data[f] = clean
    return data

def analyze_cv(text, model_choice):
    prompt = f"""
Eres un headhunter experto con 20 años de experiencia. Tu tarea es ANALIZAR e INTERPRETAR el CV.

Devuelve SOLO JSON con esta estructura:
{{
  "datos_crudos": {{
    "nombre": "", "telefono": "", "email": "", "ubicacion": "",
    "profesion_escrita": "", "universidad": "", "grado_academico": "", "anio_graduacion": "",
    "certificaciones": [], "perfil_textual": "",
    "experiencia_laboral": [  // ← NUEVO: lista de experiencias laborales
      {{
        "puesto": "",
        "empresa": "",
        "fecha_inicio": "",
        "fecha_fin": "",
        "descripcion": ""
      }}
    ],
    "experiencia_texto": "",  // Lo mantenemos por compatibilidad
    "habilidades_listadas": [], "herramientas_listadas": [], "idiomas_listados": [],
    "pretension_salarial": "", "disponibilidad": "",
    "empresas": []  // Lista única de todas las empresas (sin duplicados)
  }},
  "interpretacion": {{
    "sector_deducido": "", "anos_experiencia_deducidos": "", "seniority": "",
    "perfil_interpretado": "", "industria_principal": "", "industrias_secundarias": [],
    "habilidades_clave": [], "fortalezas": [], "areas_mejora": [],
    "rol_tipico": "", "nivel_impacto": "", "recomendacion": ""
  }}
}}

INSTRUCCIONES ESPECÍFICAS PARA EXTRAER EMPRESAS Y EXPERIENCIA LABORAL:

1. **EXPERIENCIA LABORAL**: Busca en el CV la sección de experiencia profesional. Por cada trabajo, extrae:
   - puesto: el cargo que ocupó
   - empresa: el nombre de la empresa (MUY IMPORTANTE)
   - fecha_inicio: año o fecha de inicio
   - fecha_fin: año o fecha de fin (o "Presente" si continúa)
   - descripción: breve descripción de funciones

2. **EMPRESAS**: Al final, crea una lista "empresas" con TODOS los nombres de empresas encontrados (sin repetir).

3. **EXPERIENCIA_TEXTO**: Además, guarda el texto completo de la sección de experiencia (para compatibilidad).

EJEMPLO DE CÓMO DEBE QUEDAR:
Si el CV dice:
"2018-2020: Desarrollador Java en Scotiabank
 2020-2022: Analista Senior en BAC Credomatic"

Debe quedar:
"experiencia_laboral": [
  {{"puesto": "Desarrollador Java", "empresa": "Scotiabank", "fecha_inicio": "2018", "fecha_fin": "2020", "descripcion": ""}},
  {{"puesto": "Analista Senior", "empresa": "BAC Credomatic", "fecha_inicio": "2020", "fecha_fin": "2022", "descripcion": ""}}
],
"empresas": ["Scotiabank", "BAC Credomatic"]

CV a analizar:
{text[:12000]}
"""
    if model_choice == "deepseek":
        client = deepseek_client
        model = "deepseek-chat"
    else:
        client = openai_client
        model = "gpt-4o-mini"
    response = client.chat.completions.create(
        model=model,
        messages=[{"role": "user", "content": prompt}],
        temperature=0
    )
    return safe_json_parse(response.choices[0].message.content)

def score_candidate(data):
    if "interpretacion" in data:
        interp = data["interpretacion"]
        score = 0
        if interp.get("seniority") in ["Senior", "Lead"]: score += 20
        elif interp.get("seniority") == "Semi-Senior": score += 15
        elif interp.get("seniority") == "Junior": score += 10
        if interp.get("habilidades_clave"): score += min(25, len(interp["habilidades_clave"]) * 5)
        if interp.get("fortalezas"): score += min(15, len(interp["fortalezas"]) * 3)
        if interp.get("nivel_impacto") == "Alto": score += 20
        elif interp.get("nivel_impacto") == "Medio": score += 10
        elif interp.get("nivel_impacto") == "Bajo": score += 5
        if interp.get("industria_principal"): score += 5
        if interp.get("industrias_secundarias"): score += min(5, len(interp["industrias_secundarias"]))
        exp_text = interp.get("anos_experiencia_deducidos", "")
        if "años" in exp_text:
            match = re.search(r'(\d+)', exp_text)
            if match:
                años = int(match.group(1))
                if años >= 8: score += 10
                elif años >= 5: score += 7
                elif años >= 2: score += 4
        if score >= 80: criterio = "Alta compatibilidad"
        elif score >= 60: criterio = "Compatibilidad media-alta"
        elif score >= 40: criterio = "Compatibilidad media"
        elif score >= 20: criterio = "Compatibilidad media-baja"
        else: criterio = "Perfil limitado"
        data["score"] = score
        data["criterio_ai"] = criterio
    return data

def generar_embedding_candidato(data, candidate_id):
    """Genera embedding para un candidato incluyendo TODOS los datos disponibles"""
    try:
        texto_completo = ""
        empresas_encontradas = []
        
        # ===== 1. DATOS CRUDOS (lo que está explícitamente en el CV) =====
        if "datos_crudos" in data:
            dc = data["datos_crudos"]
            
            # ===== NUEVO: EXTRAER EMPRESAS DE experiencia_laboral (si existe) =====
            if 'experiencia_laboral' in dc and dc['experiencia_laboral']:
                print(f"📋 Extrayendo empresas de experiencia_laboral estructurada...")
                for exp in dc['experiencia_laboral']:
                    if exp.get('empresa') and exp['empresa'].strip():
                        empresa = exp['empresa'].strip()
                        if empresa not in empresas_encontradas:
                            empresas_encontradas.append(empresa)
                print(f"✅ Empresas encontradas en estructura: {empresas_encontradas}")
            
            # ===== FALLBACK: Si no hay experiencia_laboral, usar el método anterior con IA =====
            if not empresas_encontradas and dc.get('experiencia_texto'):
                exp_texto = dc.get('experiencia_texto', '')
                nombre = dc.get('nombre', 'Candidato')
                
                print(f"🤖 Usando IA para extraer empresas de {nombre} (fallback)...")
                
                try:
                    prompt = f"""
Del siguiente texto de experiencia laboral de {nombre}, extrae SOLO los nombres de las empresas:

{exp_texto[:2000]}

Devuelve SOLO JSON: {{"empresas": []}}
"""
                    response = openai_client.chat.completions.create(
                        model="gpt-4o-mini",
                        messages=[{"role": "user", "content": prompt}],
                        temperature=0,
                        max_tokens=150
                    )
                    
                    contenido = response.choices[0].message.content
                    import re
                    import json
                    json_match = re.search(r'\{.*\}', contenido, re.DOTALL)
                    if json_match:
                        resultado = json.loads(json_match.group())
                        empresas_encontradas = resultado.get('empresas', [])
                        print(f"✅ IA encontró: {empresas_encontradas}")
                        
                except Exception as e:
                    print(f"⚠️ Error con IA: {e}")
            
            # ===== TAMBIÉN VERIFICAR si ya venía el campo empresas =====
            if not empresas_encontradas and dc.get('empresas'):
                empresas_encontradas = dc.get('empresas', [])
                print(f"📦 Usando empresas ya guardadas: {empresas_encontradas}")
            
            # Guardar empresas en data para futuros usos
            if empresas_encontradas:
                if 'datos_crudos' not in data:
                    data['datos_crudos'] = {}
                data['datos_crudos']['empresas'] = empresas_encontradas
            
            # Construir texto base (siempre igual)
            texto_completo += f"""
            NOMBRE: {dc.get('nombre', '')}
            PROFESIÓN ESCRITA: {dc.get('profesion_escrita', '')}
            TELÉFONO: {dc.get('telefono', '')}
            EMAIL: {dc.get('email', '')}
            UBICACIÓN: {dc.get('ubicacion', '')}
            UNIVERSIDAD: {dc.get('universidad', '')}
            GRADO ACADÉMICO: {dc.get('grado_academico', '')}
            AÑO GRADUACIÓN: {dc.get('anio_graduacion', '')}
            CERTIFICACIONES: {', '.join(dc.get('certificaciones', []))}
            PERFIL TEXTUAL: {dc.get('perfil_textual', '')}
            EXPERIENCIA TEXTO: {dc.get('experiencia_texto', '')}
            HABILIDADES LISTADAS: {', '.join(dc.get('habilidades_listadas', []))}
            HERRAMIENTAS LISTADAS: {', '.join(dc.get('herramientas_listadas', []))}
            IDIOMAS LISTADOS: {', '.join(dc.get('idiomas_listados', []))}
            PRETENSIÓN SALARIAL: {dc.get('pretension_salarial', '')}
            DISPONIBILIDAD: {dc.get('disponibilidad', '')}
            """
            
            # ===== AGREGAR EXPERIENCIA LABORAL ESTRUCTURADA (si existe) =====
            if 'experiencia_laboral' in dc and dc['experiencia_laboral']:
                texto_completo += "\nEXPERIENCIA LABORAL DETALLADA:\n"
                for exp in dc['experiencia_laboral']:
                    puesto = exp.get('puesto', '')
                    empresa = exp.get('empresa', '')
                    inicio = exp.get('fecha_inicio', '')
                    fin = exp.get('fecha_fin', '')
                    texto_completo += f"- {puesto} en {empresa} ({inicio}-{fin})\n"
                    if exp.get('descripcion'):
                        texto_completo += f"  {exp.get('descripcion', '')}\n"
            
            # Agregar empresas destacadas al texto (repetidas para darles peso)
            if empresas_encontradas:
                texto_completo += f"""
            EMPRESAS DONDE TRABAJÓ: {', '.join(empresas_encontradas)}
            EMPRESAS DESTACADAS: {', '.join(empresas_encontradas)}
            EMPRESAS DESTACADAS: {', '.join(empresas_encontradas)}
            """
        else:
            # Si no hay datos_crudos, intentar con la estructura antigua
            texto_completo += f"""
            NOMBRE: {data.get('nombre', '')}
            PROFESIÓN: {data.get('profesion', '')}
            UNIVERSIDAD: {data.get('universidad', '')}
            UBICACIÓN: {data.get('ubicacion', '')}
            TELÉFONO: {data.get('telefono', '')}
            EMAIL: {data.get('email', '')}
            EXPERIENCIA: {data.get('anos_experiencia', '')}
            SECTOR: {data.get('sector_principal', '')}
            HABILIDADES: {', '.join(data.get('habilidades', []))}
            HERRAMIENTAS: {', '.join(data.get('herramientas', []))}
            PERFIL: {data.get('perfil_profesional', '')}
            """
        
        # ===== 2. INTERPRETACIÓN IA =====
        if "interpretacion" in data:
            interp = data["interpretacion"]
            texto_completo += f"""
            SECTOR DEDUCIDO: {interp.get('sector_deducido', '')}
            AÑOS EXPERIENCIA DEDUCIDOS: {interp.get('anos_experiencia_deducidos', '')}
            SENIORITY: {interp.get('seniority', '')}
            PERFIL INTERPRETADO: {interp.get('perfil_interpretado', '')}
            INDUSTRIA PRINCIPAL: {interp.get('industria_principal', '')}
            INDUSTRIAS SECUNDARIAS: {', '.join(interp.get('industrias_secundarias', []))}
            HABILIDADES CLAVE: {', '.join(interp.get('habilidades_clave', []))}
            FORTALEZAS: {', '.join(interp.get('fortalezas', []))}
            ÁREAS DE MEJORA: {', '.join(interp.get('areas_mejora', []))}
            ROL TÍPICO: {interp.get('rol_tipico', '')}
            NIVEL DE IMPACTO: {interp.get('nivel_impacto', '')}
            RECOMENDACIÓN: {interp.get('recomendacion', '')}
            """
        
        # ===== 3. DATOS ADICIONALES =====
        texto_completo += f"""
        ARCHIVO: {data.get('archivo', '')}
        SCORE: {data.get('score', 0)}
        """
        
        # MOSTRAR EN CONSOLA PARA DEBUG
        print(f"\n{'='*60}")
        print(f"🔍 GENERANDO EMBEDDING PARA CANDIDATO ID: {candidate_id}")
        print(f"{'='*60}")
        print(f"📄 TEXTO COMPLETO ({len(texto_completo)} caracteres)")
        if empresas_encontradas:
            print(f"🏢 EMPRESAS ENCONTRADAS: {', '.join(empresas_encontradas)}")
        print(f"🔍 EMPRESAS ENCONTRADAS RAW: {empresas_encontradas}")
        print(f"📄 Tipo de datos: {type(empresas_encontradas)}")
        print(f"{'='*60}\n")
        
        # Generar embedding
        embedding = modelo_embeddings.encode(texto_completo).tolist()
        
        # Guardar en ChromaDB con metadatos enriquecidos
        metadatos = {
            "nombre": data.get('datos_crudos', {}).get('nombre') if "datos_crudos" in data else data.get('nombre', ''),
            "archivo": data['archivo'],
            "id": candidate_id
        }
        
        # Guardar empresas en metadatos para acceso rápido
        if empresas_encontradas:
            metadatos["empresas"] = ', '.join(empresas_encontradas)[:200]
        
        coleccion.upsert(
            embeddings=[embedding],
            ids=[str(candidate_id)],
            metadatas=[metadatos]
        )
        
        print(f"💾 Guardando en metadatos: {metadatos}")
        print(f"✅ Embedding guardado para candidato ID: {candidate_id}")
        return True
        
    except Exception as e:
        print(f"❌ Error generando embedding: {e}")
        import traceback
        traceback.print_exc()
        return False
def buscar_por_embedding(texto_busqueda, limite=20):
    try:
        embedding_busqueda = modelo_embeddings.encode(texto_busqueda).tolist()
        resultados = coleccion.query(query_embeddings=[embedding_busqueda], n_results=limite)
        if not resultados['ids'][0]: return []
        ids_candidatos = [int(id) for id in resultados['ids'][0]]
        distancias = resultados['distances'][0]
        max_dist = max(distancias) if distancias else 1
        similitudes = [1 - (d / max_dist) for d in distancias]
        todos = load_all_candidates_from_db()
        dicc_candidatos = {c.get('id'): c for c in todos}
        candidatos = []
        for i, id_candidato in enumerate(ids_candidatos):
            if id_candidato in dicc_candidatos:
                candidato = dicc_candidatos[id_candidato]
                candidato['similitud_semantica'] = round(similitudes[i] * 100, 1)
                candidatos.append(candidato)
        return candidatos
    except Exception as e:
        print(f"❌ Error búsqueda: {e}")
        return []

def save_candidate_to_db(data):
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    try:
        cursor.execute("SELECT id FROM candidates WHERE archivo = ?", (data['archivo'],))
        existing = cursor.fetchone()
        if "interpretacion" in data:
            nombre = data.get('datos_crudos', {}).get('nombre')
            profesion = data.get('datos_crudos', {}).get('profesion_escrita')
            universidad = data.get('datos_crudos', {}).get('universidad')
            sector_principal = data['interpretacion'].get('sector_deducido')
            anos_experiencia = data['interpretacion'].get('anos_experiencia_deducidos')
        else:
            nombre = data.get('nombre')
            profesion = data.get('profesion')
            universidad = data.get('universidad')
            sector_principal = data.get('sector_principal')
            anos_experiencia = data.get('anos_experiencia')
        if existing:
            cursor.execute('''
                UPDATE candidates SET nombre=?, telefono=?, email=?, ubicacion=?,
                profesion=?, universidad=?, grado_academico=?, anio_graduacion=?,
                perfil_profesional=?, anos_experiencia=?, sector_principal=?,
                pretension_salarial=?, disponibilidad=?, score=?, criterio_ai=?,
                fecha_analisis=?, raw_data=? WHERE archivo=?
            ''', (
                nombre,
                data.get('datos_crudos', {}).get('telefono') if "interpretacion" in data else data.get('telefono'),
                data.get('datos_crudos', {}).get('email') if "interpretacion" in data else data.get('email'),
                data.get('datos_crudos', {}).get('ubicacion') if "interpretacion" in data else data.get('ubicacion'),
                profesion, universidad,
                data.get('datos_crudos', {}).get('grado_academico') if "interpretacion" in data else data.get('grado_academico'),
                data.get('datos_crudos', {}).get('anio_graduacion') if "interpretacion" in data else data.get('anio_graduacion'),
                data.get('perfil_profesional') if "interpretacion" not in data else data.get('datos_crudos', {}).get('perfil_textual'),
                anos_experiencia, sector_principal,
                data.get('pretension_salarial') if "interpretacion" not in data else data.get('datos_crudos', {}).get('pretension_salarial'),
                data.get('disponibilidad') if "interpretacion" not in data else data.get('datos_crudos', {}).get('disponibilidad'),
                data.get('score'), data.get('criterio_ai'), datetime.now(),
                json.dumps(data, ensure_ascii=False), data['archivo']
            ))
            candidate_id = existing[0]
            cursor.execute("DELETE FROM habilidades WHERE candidate_id = ?", (candidate_id,))
            cursor.execute("DELETE FROM industrias WHERE candidate_id = ?", (candidate_id,))
            cursor.execute("DELETE FROM roles WHERE candidate_id = ?", (candidate_id,))
        else:
            cursor.execute('''
                INSERT INTO candidates (archivo, nombre, telefono, email, ubicacion,
                profesion, universidad, grado_academico, anio_graduacion,
                perfil_profesional, anos_experiencia, sector_principal,
                pretension_salarial, disponibilidad, score, criterio_ai,
                fecha_analisis, raw_data) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
            ''', (
                data['archivo'], nombre,
                data.get('datos_crudos', {}).get('telefono') if "interpretacion" in data else data.get('telefono'),
                data.get('datos_crudos', {}).get('email') if "interpretacion" in data else data.get('email'),
                data.get('datos_crudos', {}).get('ubicacion') if "interpretacion" in data else data.get('ubicacion'),
                profesion, universidad,
                data.get('datos_crudos', {}).get('grado_academico') if "interpretacion" in data else data.get('grado_academico'),
                data.get('datos_crudos', {}).get('anio_graduacion') if "interpretacion" in data else data.get('anio_graduacion'),
                data.get('perfil_profesional') if "interpretacion" not in data else data.get('datos_crudos', {}).get('perfil_textual'),
                anos_experiencia, sector_principal,
                data.get('pretension_salarial') if "interpretacion" not in data else data.get('datos_crudos', {}).get('pretension_salarial'),
                data.get('disponibilidad') if "interpretacion" not in data else data.get('datos_crudos', {}).get('disponibilidad'),
                data.get('score'), data.get('criterio_ai'), datetime.now(),
                json.dumps(data, ensure_ascii=False)
            ))
            candidate_id = cursor.lastrowid
        if "interpretacion" in data:
            for habilidad in data['interpretacion'].get('habilidades_clave', []):
                cursor.execute('INSERT INTO habilidades (candidate_id, habilidad, tipo) VALUES (?,?,?)',
                             (candidate_id, habilidad, 'habilidad_clave'))
            for fortaleza in data['interpretacion'].get('fortalezas', []):
                cursor.execute('INSERT INTO habilidades (candidate_id, habilidad, tipo) VALUES (?,?,?)',
                             (candidate_id, fortaleza, 'fortaleza'))
            if data['interpretacion'].get('industria_principal'):
                cursor.execute('INSERT INTO industrias (candidate_id, industria) VALUES (?,?)',
                             (candidate_id, data['interpretacion']['industria_principal']))
            for industria in data['interpretacion'].get('industrias_secundarias', []):
                cursor.execute('INSERT INTO industrias (candidate_id, industria) VALUES (?,?)',
                             (candidate_id, industria))
        conn.commit()
        generar_embedding_candidato(data, candidate_id)
    except Exception as e:
        print(f"❌ Error: {e}")
        conn.rollback()
    finally:
        conn.close()
    return candidate_id

def load_all_candidates_from_db():
    """Carga todos los candidatos de la BD y enriquece con datos de ChromaDB"""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT id, archivo, raw_data FROM candidates ORDER BY fecha_analisis DESC')
    rows = cursor.fetchall()
    candidates = []
    
    # Obtener TODOS los IDs para buscar en ChromaDB
    todos_ids = [str(row[0]) for row in rows]
    metadatos_dict = {}
    
    if todos_ids:
        try:
            # Obtener metadatos de ChromaDB para todos los candidatos
            resultados = coleccion.get(ids=todos_ids, include=['metadatas'])
            if resultados and 'metadatas' in resultados and 'ids' in resultados:
                for i, id_str in enumerate(resultados['ids']):
                    metadatos_dict[int(id_str)] = resultados['metadatas'][i]
                print(f"📊 Metadatos cargados para {len(metadatos_dict)} candidatos")
        except Exception as e:
            print(f"⚠️ Error obteniendo metadatos de ChromaDB: {e}")
    
    for row in rows:
        if row[2]:
            try:
                candidate = json.loads(row[2])
                candidate['id'] = row[0]
                
                # Asegurar que datos_crudos existe
                if 'datos_crudos' not in candidate:
                    candidate['datos_crudos'] = {}
                
                # ===== 1. PRIORIDAD 1: EMPRESAS DESDE METADATOS =====
                if row[0] in metadatos_dict and 'empresas' in metadatos_dict[row[0]]:
                    empresas_str = metadatos_dict[row[0]]['empresas']
                    if empresas_str and isinstance(empresas_str, str):
                        # Convertir string de empresas a lista
                        candidate['datos_crudos']['empresas'] = [e.strip() for e in empresas_str.split(',') if e.strip()]
                        print(f"✅ Empresas desde metadatos para ID {row[0]}: {candidate['datos_crudos']['empresas']}")
                
                # ===== 2. PRIORIDAD 2: EMPRESAS DESDE experiencia_laboral =====
                elif 'experiencia_laboral' in candidate['datos_crudos']:
                    exp_laboral = candidate['datos_crudos']['experiencia_laboral']
                    if exp_laboral and isinstance(exp_laboral, list):
                        empresas = []
                        for exp in exp_laboral:
                            if isinstance(exp, dict) and exp.get('empresa'):
                                empresa = exp['empresa'].strip()
                                if empresa and empresa not in empresas:
                                    empresas.append(empresa)
                        if empresas:
                            candidate['datos_crudos']['empresas'] = empresas
                            print(f"✅ Empresas desde experiencia_laboral para ID {row[0]}: {empresas}")
                
                # ===== 3. PRIORIDAD 3: EMPRESAS YA GUARDADAS EN datos_crudos =====
                elif 'empresas' in candidate['datos_crudos'] and candidate['datos_crudos']['empresas']:
                    # Ya están, no hacer nada
                    print(f"✅ Empresas ya existentes para ID {row[0]}: {candidate['datos_crudos']['empresas']}")
                
                # ===== 4. SI NO HAY EMPRESAS, LISTA VACÍA =====
                else:
                    candidate['datos_crudos']['empresas'] = []
                    print(f"ℹ️ Sin empresas para ID {row[0]}")
                
                candidates.append(candidate)
                
            except json.JSONDecodeError as e:
                print(f"❌ Error parseando JSON para ID {row[0]}: {e}")
                continue
    
    conn.close()
    print(f"📤 Devolviendo {len(candidates)} candidatos con datos enriquecidos")
    return candidates

def extract_pdf(path):
    text = ""
    with pdfplumber.open(path) as pdf:
        for page in pdf.pages:
            text += page.extract_text() or ""
    return text

def extract_docx(path):
    text = ""
    try:
        with open(path, "rb") as docx_file:
            result = mammoth.extract_raw_text(docx_file)
            text = result.value
            if len(text) > 50: return text
    except: pass
    try:
        doc = docx.Document(path)
        parts = []
        for para in doc.paragraphs:
            if para.text.strip(): parts.append(para.text)
        for table in doc.tables:
            for row in table.rows:
                for cell in row.cells:
                    if cell.text.strip(): parts.append(cell.text)
        text = "\n".join(parts)
        if len(text) > 50: return text
    except: pass
    try: text = docx2txt.process(path)
    except: pass
    return text

def extract_text(path):
    if path.lower().endswith(".pdf"): return extract_pdf(path)
    if path.lower().endswith(".docx"): return extract_docx(path)
    return ""

