@app.route("/api/ranking-ia", methods=["POST"])
def ranking_ia():
    """Ranking fino con ChatGPT sobre resultados de embeddings"""
    try:
        data = request.json
        candidatos = data.get('candidatos', [])
        query = data.get('query', '')
        model = data.get('model', 'gpt')
        
        print(f"📥 Ranking IA para: '{query}' con {len(candidatos)} candidatos")
        
        if not candidatos or not query:
            return jsonify({"success": False, "error": "Faltan datos"}), 400
        
        # Limitar a 10 candidatos para no saturar
        candidatos_limit = candidatos[:10]
        
        # Preparar resumen para ChatGPT
        resumen = "Candidatos a evaluar:\n\n"
        for i, c in enumerate(candidatos_limit):
            if "interpretacion" in c:
                resumen += f"{i+1}. {c.get('datos_crudos', {}).get('nombre', 'Sin nombre')}\n"
                resumen += f"   Perfil: {c['interpretacion'].get('perfil_interpretado', '')[:200]}\n"
                resumen += f"   Habilidades: {', '.join(c['interpretacion'].get('habilidades_clave', []))}\n"
                resumen += f"   Experiencia: {c['interpretacion'].get('anos_experiencia_deducidos', '')}\n"
                resumen += f"   Seniority: {c['interpretacion'].get('seniority', '')}\n\n"
            else:
                resumen += f"{i+1}. {c.get('nombre', 'Sin nombre')}\n"
                resumen += f"   Perfil: {c.get('perfil_profesional', '')[:200]}\n"
                resumen += f"   Habilidades: {', '.join(c.get('habilidades', []))}\n"
                resumen += f"   Experiencia: {c.get('anos_experiencia', '')}\n\n"
        
        prompt = f"""
Eres un headhunter experto. Te voy a dar:
1. Una búsqueda: "{query}"
2. Una lista de {len(candidatos_limit)} candidatos preseleccionados

Tu tarea es:
- Analizar cada candidato
- Ordenarlos del MEJOR al PEOR para esta búsqueda específica
- Dar una explicación breve de por qué el #1 es el mejor

Devuelve SOLO JSON con este formato:
{{
  "ranking": [1, 3, 2, 5, 4, ...],  // Números de candidato en orden de mejor a peor
  "mejor_explicacion": "Ana es la mejor porque...",
  "analisis": "Observaciones generales sobre los candidatos..."
}}

{resumen}
"""
        
        # Elegir modelo
        if model == "deepseek":
            client = deepseek_client
            model_name = "deepseek-chat"
        else:
            client = openai_client
            model_name = "gpt-4o-mini"
        
        response = client.chat.completions.create(
            model=model_name,
            messages=[{"role": "user", "content": prompt}],
            temperature=0
        )
        
        result = response.choices[0].message.content
        ranking_data = safe_json_parse(result)
        
        # Reordenar candidatos según ranking
        ranking_ids = ranking_data.get('ranking', [])
        candidatos_ordenados = []
        for pos in ranking_ids:
            if 1 <= pos <= len(candidatos_limit):
                candidatos_ordenados.append(candidatos_limit[pos-1])
        
        # Agregar el resto de candidatos (los que no estaban en el ranking)
        for c in candidatos:
            if c not in candidatos_ordenados:
                candidatos_ordenados.append(c)
        
        print(f"✅ Ranking completado")
        
        return jsonify({
            "success": True,
            "data": candidatos_ordenados,
            "explicacion": ranking_data.get('mejor_explicacion', ''),
            "analisis": ranking_data.get('analisis', '')
        })
        
    except Exception as e:
        print(f"❌ Error en ranking: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500
@app.route("/api/reindex-embeddings", methods=["GET", "POST"])  # Acepta GET también
def reindex_embeddings():
    """Reconstruye todos los embeddings con la nueva información completa"""
    try:
        print("🔄 Iniciando reindexación completa de embeddings...")
        candidatos = load_all_candidates_from_db()
        print(f"📊 Total de candidatos: {len(candidatos)}")
        
        exitos = 0
        errores = 0
        
        for i, c in enumerate(candidatos):
            print(f"⏳ Procesando {i+1}/{len(candidatos)}: {c.get('archivo', 'desconocido')}")
            if generar_embedding_candidato(c, c['id']):
                exitos += 1
            else:
                errores += 1
        
        print(f"✅ Reindexación completada: {exitos} éxitos, {errores} errores")
        
        # Verificar cuántos embeddings hay ahora
        count = coleccion.count()
        print(f"📈 Total de embeddings en ChromaDB: {count}")
        
        return jsonify({
            "success": True,
            "message": f"Reindexación completada: {exitos} éxitos, {errores} errores",
            "total_embeddings": count
        })
        
    except Exception as e:
        print(f"❌ Error en reindexación: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500
    

@app.route("/api/asistente", methods=["POST"])
def asistente_inteligente():
    """Headhunter experto que responde CUALQUIER pregunta en lenguaje natural"""
    try:
        data = request.json
        mensaje = data.get('mensaje', '')
        
        print(f"\n{'='*60}")
        print(f"🤵 HEADHUNTER: '{mensaje}'")
        print(f"{'='*60}")
        
        # ===== PASO 1: DETECTAR QUÉ ESTÁ BUSCANDO EL USUARIO =====
        prompt_deteccion = f"""
Eres un headhunter experto. Analiza esta pregunta de un cliente y determina EXACTAMENTE qué está buscando.

Pregunta: "{mensaje}"

Devuelve SOLO JSON con esta estructura:
{{
  "tipo": "rol" | "ubicacion" | "universidad" | "habilidad" | "empresa" | "experiencia" | "recomendacion" | "conteo" | "general",
  "rol_buscado": "el rol específico (programador, gerente, secretaria, etc.)" o null,
  "lugar": "lugar mencionado (Liberia, Cartago, San José, etc.)" o null,
  "universidad": "universidad mencionada (UCR, TEC, UNA, etc.)" o null,
  "habilidad": "habilidad mencionada (Java, Python, inglés, etc.)" o null,
  "empresa": "empresa mencionada (Scotiabank, BAC, etc.)" o null,
  "seniority": "senior | semi-senior | junior | null",
  "min_experiencia": años mínimos de experiencia (número) o null,
  "es_recomendacion": true si pide "mejor", "top", "recomienda", "el mejor",
  "cantidad": número de resultados que pide (1 para "el mejor", 3 para "top 3", null para todos)
}}

Sé preciso. Si la pregunta es "programadores", el rol_buscado es "programador".
Si es "gente de Cartago", el lugar es "Cartago".
Si es "el mejor desarrollador", es_recomendacion es true y rol_buscado es "desarrollador".
"""
        
        response_deteccion = openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt_deteccion}],
            temperature=0
        )
        
        deteccion = safe_json_parse(response_deteccion.choices[0].message.content)
        print(f"🔍 Cliente busca: {deteccion}")
        
        tipo = deteccion.get('tipo', 'general')
        rol_buscado = deteccion.get('rol_buscado', '').lower() if deteccion.get('rol_buscado') else None
        lugar = deteccion.get('lugar', '').lower() if deteccion.get('lugar') else None
        universidad = deteccion.get('universidad', '').lower() if deteccion.get('universidad') else None
        habilidad = deteccion.get('habilidad', '').lower() if deteccion.get('habilidad') else None
        empresa = deteccion.get('empresa', '').lower() if deteccion.get('empresa') else None
        seniority = deteccion.get('seniority', '').lower() if deteccion.get('seniority') else None
        min_experiencia = deteccion.get('min_experiencia')
        es_recomendacion = deteccion.get('es_recomendacion', False)
        cantidad = deteccion.get('cantidad', 10)
        
        # ===== PASO 2: CONSTRUIR CONSULTA PARA EMBEDDINGS =====
        terminos = []
        if rol_buscado:
            terminos.append(rol_buscado)
        if lugar:
            terminos.append(lugar)
        if universidad:
            terminos.append(universidad)
        if habilidad:
            terminos.append(habilidad)
        if empresa:
            terminos.append(empresa)
        
        consulta = " ".join(terminos) if terminos else mensaje
        print(f"🔍 Consulta embeddings: '{consulta}'")
        
        # Buscar los 30 candidatos más relevantes
        candidatos = buscar_por_embedding(consulta, 30)
        print(f"✅ Encontrados {len(candidatos)} candidatos relacionados")
        
        if not candidatos:
            return jsonify({
                "success": True,
                "respuesta": f"No encontré ningún candidato relacionado con '{mensaje}'. ¿Quieres que busque perfiles similares?"
            })
        
        # ===== PASO 3: FILTRAR POR CRITERIOS ESPECÍFICOS =====
        filtrados = []
        
        for c in candidatos:
            incluir = True
            razones = []
            
            # Extraer información del candidato
            nombre = c.get('datos_crudos', {}).get('nombre', 'N/A')
            profesion = c.get('datos_crudos', {}).get('profesion_escrita', '').lower()
            perfil = c.get('interpretacion', {}).get('perfil_interpretado', '').lower()
            rol_tipico = c.get('interpretacion', {}).get('rol_tipico', '').lower()
            ubicacion = c.get('datos_crudos', {}).get('ubicacion', '').lower()
            uni = c.get('datos_crudos', {}).get('universidad', '').lower()
            habilidades = [h.lower() for h in c.get('interpretacion', {}).get('habilidades_clave', [])]
            exp_text = c.get('interpretacion', {}).get('anos_experiencia_deducidos', '0')
            seniority_cand = c.get('interpretacion', {}).get('seniority', '').lower()
            
            # Extraer años de experiencia
            import re
            años = 0
            match = re.search(r'(\d+)', exp_text)
            if match:
                años = int(match.group(1))
            
            # Filtrar por rol
            if rol_buscado and incluir:
                if not (rol_buscado in profesion or rol_buscado in perfil or rol_buscado in rol_tipico):
                    # No descartar completamente, pero marcar como menos relevante
                    pass
            
            # Filtrar por ubicación
            if lugar and incluir:
                if lugar not in ubicacion:
                    incluir = False
                    razones.append(f"no vive en {lugar}")
            
            # Filtrar por universidad
            if universidad and incluir:
                if universidad not in uni:
                    incluir = False
                    razones.append(f"no estudió en {universidad}")
            
            # Filtrar por habilidad
            if habilidad and incluir:
                if not any(habilidad in h for h in habilidades):
                    # No descartar, pero afectará el score
                    pass
            
            # Filtrar por empresa
            if empresa and incluir:
                exp_texto = c.get('datos_crudos', {}).get('experiencia_texto', '').lower()
                if empresa not in exp_texto:
                    incluir = False
                    razones.append(f"no trabajó en {empresa}")
            
            # Filtrar por experiencia mínima
            if min_experiencia and incluir:
                if años < min_experiencia:
                    incluir = False
                    razones.append(f"solo tiene {años} años de experiencia")
            
            # Calcular score de relevancia
            score_base = c.get('similitud_semantica', 50)
            
            # Bonus por coincidencia de rol
            if rol_buscado and (rol_buscado in profesion or rol_buscado in perfil):
                score_base += 20
            
            # Bonus por seniority
            if seniority and seniority in seniority_cand:
                score_base += 15
            
            # Bonus por habilidad
            if habilidad and any(habilidad in h for h in habilidades):
                score_base += 10
            
            c['score_final'] = min(100, score_base)
            c['años'] = años
            c['seniority_cand'] = seniority_cand
            c['razones_exclusion'] = razones if not incluir else []
            
            if incluir:
                filtrados.append(c)
        
        # ===== PASO 4: SI NO HAY FILTRADOS, USAR LOS MÁS CERCANOS =====
        if not filtrados and candidatos:
            # Tomar los 5 mejores aunque no cumplan todos los filtros
            filtrados = candidatos[:5]
            for c in filtrados:
                c['score_final'] = c.get('similitud_semantica', 50)
            modo_fallback = True
        else:
            modo_fallback = False
        
        # Ordenar por score final
        filtrados.sort(key=lambda x: x['score_final'], reverse=True)
        
        # Limitar a la cantidad solicitada
        if cantidad and cantidad < len(filtrados):
            filtrados = filtrados[:cantidad]
        
        # ===== PASO 5: PREPARAR CONTEXTO PARA EL HEADHUNTER =====
        contexto = f"**Cliente pregunta:** '{mensaje}'\n\n"
        contexto += f"**Mi análisis:** Busca {tipo}"
        if rol_buscado:
            contexto += f" - Rol: {rol_buscado}"
        if lugar:
            contexto += f" - Lugar: {lugar}"
        if universidad:
            contexto += f" - Universidad: {universidad}"
        if habilidad:
            contexto += f" - Habilidad: {habilidad}"
        if seniority:
            contexto += f" - Seniority: {seniority}"
        if min_experiencia:
            contexto += f" - Mínimo {min_experiencia} años"
        contexto += "\n\n"
        
        if modo_fallback:
            contexto += "⚠️ **Nota:** No encontré candidatos que cumplan exactamente todos los criterios. Te muestro los más cercanos:\n\n"
        else:
            contexto += f"✅ **Encontré {len(filtrados)} candidatos que cumplen tus criterios:**\n\n"
        
        for i, c in enumerate(filtrados[:8]):  # Mostrar máximo 8 en el contexto
            nombre = c.get('datos_crudos', {}).get('nombre', 'N/A')
            profesion = c.get('datos_crudos', {}).get('profesion_escrita', 'N/A')
            score = c.get('score_final', c.get('similitud_semantica', 0))
            años = c.get('años', 0)
            seniority_cand = c.get('seniority_cand', 'No especificado')
            ubicacion = c.get('datos_crudos', {}).get('ubicacion', 'N/A')
            universidad_cand = c.get('datos_crudos', {}).get('universidad', 'N/A')
            habilidades = c.get('interpretacion', {}).get('habilidades_clave', [])[:4]
            
            contexto += f"**{i+1}. {nombre}**\n"
            contexto += f"   📋 Perfil: {profesion}\n"
            contexto += f"   📊 Compatibilidad: {score:.0f}%\n"
            contexto += f"   📍 Ubicación: {ubicacion}\n"
            if universidad_cand != 'N/A':
                contexto += f"   🎓 Universidad: {universidad_cand}\n"
            contexto += f"   ⏱️ Experiencia: {años} años ({seniority_cand})\n"
            if habilidades:
                contexto += f"   🔧 Habilidades: {', '.join(habilidades)}\n"
            contexto += "\n"
        
        if len(filtrados) > 8:
            contexto += f"... y {len(filtrados) - 8} más.\n\n"
        
        # ===== PASO 6: EL HEADHUNTER DA SU OPINIÓN =====
        prompt_headhunter = f"""
Eres un headhunter con MÁS DE 20 AÑOS DE EXPERIENCIA. Has reclutado para cientos de empresas y tienes un ojo clínico para el talento.

{contexto}

Ahora, ACTÚA COMO HEADHUNTER y responde al cliente. Tu respuesta debe incluir:

1. **MI ANÁLISIS PROFESIONAL**: ¿Qué opinas de este grupo de candidatos? ¿Hay realmente lo que busca?

2. **MI RECOMENDACIÓN**: ¿A quién recomendarías y POR QUÉ? (sé específico, menciona nombres y fortalezas concretas)

3. **COMPARATIVA**: ¿Cómo se comparan entre sí? (fortalezas/debilidades relativas)

4. **CONSEJO DE EXPERTO**: ¿Alguna sugerencia para su proceso de selección o para ajustar la búsqueda?

**REGLAS DE ORO:**
- Habla en PRIMERA PERSONA ("Yo recomiendo...", "Mi experiencia me dice...")
- Sé 100% honesto. Si no hay candidatos ideales, DILO CLARAMENTE.
- No inventes perfiles que no existen.
- Usa tu criterio de experto para DESTACAR al mejor candidato.
- Menciona nombres específicos cuando corresponda.
- Sé conversacional pero profesional.

Responde como el headhunter experto que eres.
"""
        
        response_headhunter = openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt_headhunter}],
            temperature=0.7,
            max_tokens=800
        )
        
        opinion = response_headhunter.choices[0].message.content
        
        return jsonify({
            "success": True,
            "respuesta": opinion,
            "stats": {
                "encontrados": len(filtrados),
                "total_busqueda": len(candidatos),
                "modo_fallback": modo_fallback
            }
        })
        
    except Exception as e:
        print(f"❌ Error en asistente: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500
    

@app.route("/api/migrar-experiencia", methods=["GET"])
def migrar_experiencia():
    """Migra candidatos antiguos: extrae experiencia_laboral y empresas usando IA"""
    try:
        candidatos = load_all_candidates_from_db()
        resultados = []
        
        for c in candidatos:
            c_id = c.get('id')
            nombre = c.get('datos_crudos', {}).get('nombre', 'Sin nombre')
            
            # Verificar si ya tiene experiencia_laboral
            if 'experiencia_laboral' in c.get('datos_crudos', {}):
                resultados.append({
                    "id": c_id,
                    "nombre": nombre,
                    "estado": "ya tiene estructura",
                    "empresas": c['datos_crudos'].get('empresas', [])
                })
                continue
            
            # Si no tiene, extraer del experiencia_texto
            exp_texto = c.get('datos_crudos', {}).get('experiencia_texto', '')
            if not exp_texto:
                resultados.append({
                    "id": c_id,
                    "nombre": nombre,
                    "estado": "sin experiencia_texto"
                })
                continue
            
            print(f"🤖 Extrayendo experiencia para {nombre}...")
            
            prompt = f"""
Del siguiente texto de experiencia laboral, extrae CADA trabajo como un objeto estructurado.

TEXTO:
{exp_texto[:3000]}

Devuelve SOLO JSON con:
{{
  "experiencia_laboral": [
    {{
      "puesto": "cargo",
      "empresa": "nombre empresa",
      "fecha_inicio": "año o fecha",
      "fecha_fin": "año o fecha",
      "descripcion": "descripción breve"
    }}
  ],
  "empresas": ["lista única de empresas"]
}}

Si no hay información, devuelve listas vacías.
"""
            
            response = openai_client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[{"role": "user", "content": prompt}],
                temperature=0,
                max_tokens=500
            )
            
            contenido = response.choices[0].message.content
            import re, json
            json_match = re.search(r'\{.*\}', contenido, re.DOTALL)
            
            if json_match:
                resultado = json.loads(json_match.group())
                
                # Actualizar el candidato en la base de datos
                if 'datos_crudos' not in c:
                    c['datos_crudos'] = {}
                
                c['datos_crudos']['experiencia_laboral'] = resultado.get('experiencia_laboral', [])
                c['datos_crudos']['empresas'] = resultado.get('empresas', [])
                
                # Guardar en SQLite
                conn = sqlite3.connect(DB_PATH)
                cursor = conn.cursor()
                cursor.execute('''
                    UPDATE candidates SET raw_data = ? WHERE id = ?
                ''', (json.dumps(c, ensure_ascii=False), c_id))
                conn.commit()
                conn.close()
                
                # Regenerar embedding
                generar_embedding_candidato(c, c_id)
                
                resultados.append({
                    "id": c_id,
                    "nombre": nombre,
                    "estado": "migrado",
                    "experiencias": len(c['datos_crudos']['experiencia_laboral']),
                    "empresas": c['datos_crudos']['empresas']
                })
            else:
                resultados.append({
                    "id": c_id,
                    "nombre": nombre,
                    "estado": "error parseando respuesta"
                })
        
        return jsonify({
            "success": True,
            "migracion": resultados
        })
        
    except Exception as e:
        print(f"❌ Error en migración: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500    
    

@app.route("/api/debug-candidato", methods=["GET"])
def debug_candidato():
    """Depura cualquier candidato - muestra su experiencia_texto y empresas"""
    try:
        # Obtener parámetros de búsqueda
        candidato_id = request.args.get('id', type=int)
        nombre_buscar = request.args.get('nombre', '')
        
        candidatos = load_all_candidates_from_db()
        resultados = []
        
        for c in candidatos:
            # Obtener datos básicos
            c_id = c.get('id')
            nombre = c.get('datos_crudos', {}).get('nombre', 'Sin nombre')
            exp_texto = c.get('datos_crudos', {}).get('experiencia_texto', '')
            empresas = c.get('datos_crudos', {}).get('empresas', [])
            
            # Verificar si coincide con la búsqueda
            coincide = False
            if candidato_id and c_id == candidato_id:
                coincide = True
            elif nombre_buscar and nombre_buscar.lower() in nombre.lower():
                coincide = True
            elif not candidato_id and not nombre_buscar:
                # Si no hay filtros, mostrar todos (limitado)
                coincide = True
            
            if coincide:
                # Extraer posibles empresas del texto (para comparar)
                import re
                posibles_empresas = []
                if exp_texto:
                    # Buscar palabras con mayúsculas que podrían ser empresas
                    palabras = exp_texto.split()
                    for palabra in palabras[:20]:  # Solo primeras 20 para no saturar
                        limpia = re.sub(r'[.,;:!?()]', '', palabra)
                        if len(limpia) > 3 and limpia[0].isupper() and limpia[0] != limpia[0].lower():
                            if limpia not in ['Trabajé', 'Experiencia', 'Laboré', 'Durante', 'Como', 'Para', 'En', 'El', 'La', 'Los', 'Las']:
                                posibles_empresas.append(limpia)
                
                resultados.append({
                    "id": c_id,
                    "nombre": nombre,
                    "longitud_experiencia": len(exp_texto),
                    "primeros_200": exp_texto[:200] + "..." if len(exp_texto) > 200 else exp_texto,
                    "empresas_guardadas": empresas,
                    "empresas_detectadas_texto": posibles_empresas[:10],
                    "tiene_empresas": len(empresas) > 0
                })
        
        if not resultados:
            return jsonify({
                "success": False,
                "error": "No se encontraron candidatos con ese criterio"
            })
        
        return jsonify({
            "success": True,
            "total_encontrados": len(resultados),
            "candidatos": resultados
        })
        
    except Exception as e:
        print(f"❌ Error en debug: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500  

@app.route("/api/match-empleo", methods=["POST"])
def match_empleo():
    """Encuentra los mejores candidatos para una descripción de empleo"""
    try:
        data = request.json
        descripcion = data.get('descripcion', '')
        titulo = data.get('titulo', 'Posición')
        cantidad = data.get('cantidad', 10)
        
        print(f"\n{'='*60}")
        print(f"🎯 MATCH EMPLEO: {titulo}")
        print(f"📝 Descripción: {descripcion[:200]}...")
        print(f"{'='*60}")
        
        # Paso 1: Usar IA para extraer keywords de la descripción
        prompt_keywords = f"""
Eres un experto en reclutamiento. Analiza esta descripción de empleo y extrae las palabras clave más importantes para buscar candidatos.

Título: {titulo}
Descripción: {descripcion}

Devuelve SOLO JSON con:
{{
  "keywords": ["palabra1", "palabra2"],
  "habilidades_requeridas": ["skill1", "skill2"],
  "seniority": "junior" | "semi-senior" | "senior" | "lead",
  "años_experiencia": número,
  "sector": "industria"
}}
"""
        response_keywords = openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt_keywords}],
            temperature=0
        )
        
        keywords_data = safe_json_parse(response_keywords.choices[0].message.content)
        print(f"🔑 Keywords extraídas: {keywords_data}")
        
        # Paso 2: Construir consulta para embeddings
        consulta = " ".join(keywords_data.get('keywords', []))
        if not consulta:
            consulta = descripcion[:200]
        
        # Buscar candidatos (más de los necesarios para luego filtrar)
        candidatos = buscar_por_embedding(consulta, cantidad * 3)
        
        # Paso 3: Calcular match score para cada candidato
        resultados = []
        for c in candidatos:
            # Score base de similitud semántica
            score = c.get('similitud_semantica', 50)
            
            # Extraer años de experiencia
            exp_text = c.get('interpretacion', {}).get('anos_experiencia_deducidos', '0')
            import re
            años = 0
            match = re.search(r'(\d+)', exp_text)
            if match:
                años = int(match.group(1))
            
            # Bonus por seniority
            seniority_cand = c.get('interpretacion', {}).get('seniority', '').lower()
            seniority_req = keywords_data.get('seniority', '').lower()
            if seniority_req and seniority_req in seniority_cand:
                score += 15
            
            # Bonus por años de experiencia
            req_años = keywords_data.get('años_experiencia', 0)
            if req_años and años >= req_años:
                score += 10
            elif req_años and años >= req_años - 2:
                score += 5
            
            # Bonus por habilidades requeridas
            habilidades_req = keywords_data.get('habilidades_requeridas', [])
            if habilidades_req:
                habilidades_cand = c.get('interpretacion', {}).get('habilidades_clave', [])
                habilidades_cand_low = [h.lower() for h in habilidades_cand]
                
                for hab in habilidades_req:
                    if hab.lower() in habilidades_cand_low:
                        score += 10
            
            # Score final
            c['match_score'] = round(min(100, score), 1)
            c['años_exp'] = años
            resultados.append(c)
        
        # Ordenar por match score
        resultados.sort(key=lambda x: x['match_score'], reverse=True)
        
        # Tomar los mejores
        mejores = resultados[:cantidad]
        
        print(f"✅ Mejores matches: {len(mejores)} candidatos")
        
        return jsonify({
            "success": True,
            "empleo": {
                "titulo": titulo,
                "descripcion": descripcion[:200],
                "keywords": keywords_data
            },
            "candidatos": mejores,
            "total": len(mejores)
        })
        
    except Exception as e:
        print(f"❌ Error en match empleo: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500    

