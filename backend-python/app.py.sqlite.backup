@app.route("/api/extraer-empresas", methods=["POST"])
def extraer_empresas_ia():
    """Usa IA para extraer empresas del texto de experiencia laboral"""
    try:
        data = request.json
        experiencia_texto = data.get('experiencia', '')
        nombre_candidato = data.get('nombre', 'Candidato')
        
        print(f"\n{'='*60}")
        print(f"🏢 EXTRAYENDO EMPRESAS PARA: {nombre_candidato}")
        print(f"{'='*60}")
        
        if not experiencia_texto or len(experiencia_texto) < 20:
            print("⚠️ Texto de experiencia muy corto o vacío")
            return jsonify({"success": True, "empresas": []})
        
        # Limitar texto para no saturar
        texto_limitado = experiencia_texto[:3000]
        print(f"📄 Texto a analizar: {len(texto_limitado)} caracteres")
        
        prompt = f"""
Eres un asistente experto en análisis de currículums y extracción de información laboral.

A continuación tienes la sección de EXPERIENCIA LABORAL de {nombre_candidato}:

---
{texto_limitado}
---

Tu tarea es identificar y listar TODAS las EMPRESAS donde ha trabajado esta persona.

REGLAS IMPORTANTES:
1. Extrae SOLO nombres de empresas, no cargos, no fechas, no descripciones de funciones
2. Si una empresa se repite (ej. "Scotiabank" varias veces), inclúyela UNA SOLA vez
3. Ignora palabras genéricas como "la empresa", "dicha compañía", "la organización"
4. Si el texto menciona "BAC", "BAC Credomatic", inclúyelo como "BAC Credomatic"
5. Si menciona "Microsoft", "Google", "Amazon", etc., inclúyelos
6. Si menciona múltiples empresas, inclúyelas todas
7. Si NO encuentras ninguna empresa, devuelve lista vacía
8. Presta atención a formatos como:
   - "Trabajé en [Empresa] como..."
   - "Experiencia en [Empresa] (2018-2022)"
   - "Laboré para [Empresa]"
   - "En [Empresa] desempeñé..."
   - "Empleado en [Empresa]"

Devuelve SOLO un JSON con este formato:
{{"empresas": ["Nombre Empresa 1", "Nombre Empresa 2", ...]}}

EJEMPLOS CORRECTOS:
- Input: "Trabajé en Scotiabank como ejecutivo de cuentas (2018-2020). Luego en BAC Credomatic."
  Output: {{"empresas": ["Scotiabank", "BAC Credomatic"]}}

- Input: "Experiencia en Microsoft y posteriormente en Google como desarrollador senior"
  Output: {{"empresas": ["Microsoft", "Google"]}}

- Input: "Fui gerente en varias empresas del sector financiero"
  Output: {{"empresas": []}}  (porque no hay nombres específicos)

- Input: "Laboré para Amazon Web Services (AWS) y después en Meta"
  Output: {{"empresas": ["Amazon Web Services", "Meta"]}}

AHORA, extrae las empresas del texto proporcionado:
"""
        
        print("⏳ Llamando a OpenAI para extraer empresas...")
        
        response = openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[
                {"role": "system", "content": "Eres un extractor de información preciso. Solo devuelves JSON válido."},
                {"role": "user", "content": prompt}
            ],
            temperature=0,
            max_tokens=300
        )
        
        contenido = response.choices[0].message.content
        print(f"📥 Respuesta de OpenAI: {contenido[:200]}...")
        
        # Intentar parsear JSON
        try:
            # Buscar JSON en la respuesta
            import re
            json_match = re.search(r'\{.*\}', contenido, re.DOTALL)
            if json_match:
                resultado = json.loads(json_match.group())
            else:
                resultado = json.loads(contenido)
        except:
            # Si falla, usar función segura
            resultado = safe_json_parse(contenido)
        
        empresas = resultado.get('empresas', [])
        
        # Limpiar y validar empresas
        empresas_limpias = []
        for emp in empresas:
            if isinstance(emp, str):
                emp_limpia = emp.strip()
                # Eliminar puntuación al final
                emp_limpia = re.sub(r'[.,;:!?]$', '', emp_limpia)
                # Validar que no sea demasiado corta o genérica
                if (len(emp_limpia) > 2 and 
                    emp_limpia.lower() not in ['empresa', 'compañía', 'corporación', 'banco', 'la empresa']):
                    empresas_limpias.append(emp_limpia)
        
        # Eliminar duplicados
        empresas_unicas = list(set(empresas_limpias))
        
        print(f"✅ Empresas extraídas para {nombre_candidato}: {empresas_unicas}")
        print(f"{'='*60}\n")
        
        return jsonify({
            "success": True,
            "empresas": empresas_unicas
        })
        
    except Exception as e:
        print(f"❌ Error extrayendo empresas: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500

@app.route("/api/analyze-search", methods=["POST"])
def analyze_search():
    """Analiza la intención de búsqueda del usuario - VERSIÓN MEJORADA"""
    try:
        data = request.json
        query = data.get('query', '')
        
        prompt = f"""
Eres un headhunter experto. Analiza esta búsqueda de reclutamiento y extrae TODA la información relevante.

Búsqueda: "{query}"

Extrae:
- LUGARES (ciudades, provincias, países, regiones)
- UNIVERSIDADES (cualquier mención de instituciones educativas)
- HABILIDADES técnicas o blandas
- ROL o puesto buscado
- SECTOR o industria
- SENIORITY requerido
- EXCLUIR perfiles que no sirven

Devuelve SOLO JSON con esta estructura:
{{
  "lugares": ["lista", "de", "lugares", "mencionados"],
  "universidades": ["lista", "de", "universidades"],
  "habilidades": ["lista", "de", "habilidades"],
  "rol_buscado": "el rol o puesto que busca",
  "sector": "sector o industria mencionada",
  "seniority": "seniority requerido (si menciona)",
  "excluir": ["tipos", "de", "perfiles", "que", "no", "sirven"],
  "texto_original": "{query}"
}}

IMPORTANTE: 
- Si menciona "universidad de Costa Rica", "UCR", o similar, inclúyelo en universidades.
- Si menciona "Liberia", "Guanacaste", "San José", etc., inclúyelo en lugares.
- Si menciona habilidades como "Python", "Java", "office", inclúyelo en habilidades.
"""
        
        response = openai_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt}],
            temperature=0
        )
        
        analysis = safe_json_parse(response.choices[0].message.content)
        print(f"📊 Análisis extraído: {analysis}")
        
        return jsonify({"success": True, "analysis": analysis})
        
    except Exception as e:
        print(f"❌ Error en analyze-search: {e}")
        return jsonify({"success": False, "error": str(e)}), 500


@app.route("/api/search-embedding-enhanced", methods=["POST"])
def search_embedding_enhanced():
    """Búsqueda semántica simplificada pero efectiva"""
    try:
        data = request.json
        query = data.get('query', '')
        analysis = data.get('analysis', {})
        limite = data.get('limite', 30)
        
        print(f"📥 Búsqueda: '{query}'")
        print(f"📋 Análisis: {analysis}")
        
        # Extraer términos útiles del análisis
        lugares = analysis.get('lugares', [])
        universidades = analysis.get('universidades', [])
        habilidades = analysis.get('habilidades', [])
        
        # Construir consulta enriquecida
        query_enriquecida = query
        if lugares:
            query_enriquecida += " " + " ".join(lugares)
        if universidades:
            query_enriquecida += " " + " ".join(universidades)
        if habilidades:
            query_enriquecida += " " + " ".join(habilidades)
        
        print(f"🔍 Consulta enriquecida: {query_enriquecida}")
        
        # Búsqueda semántica base
        candidatos = buscar_por_embedding(query_enriquecida, limite * 2)
        
        # Si no hay resultados con la consulta enriquecida, intentar con la original
        if len(candidatos) == 0:
            print("⚠️ Sin resultados, intentando con consulta original")
            candidatos = buscar_por_embedding(query, limite * 2)
        
        print(f"📊 Resultados base: {len(candidatos)} candidatos")
        
        # SIMPLEMENTE DEVOLVER LOS RESULTADOS CON SU SIMILITUD
        for c in candidatos:
            c['relevancia'] = c.get('similitud_semantica', 50)
        
        print(f"✅ Devolviendo {len(candidatos)} candidatos")
        
        return jsonify({
            "success": True,
            "data": candidatos[:limite],
            "total": len(candidatos)
        })
        
    except Exception as e:
        print(f"❌ Error: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500

