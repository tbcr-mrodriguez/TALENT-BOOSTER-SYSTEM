@app.route("/api/entrevista/resultado-detallado/<int:entrevista_id>", methods=["GET"])
def resultado_entrevista_detallado(entrevista_id):
    """Obtiene el resultado detallado de una entrevista con análisis IA"""
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        # 1. Obtener información de la entrevista
        cursor.execute('''
            SELECT e.id, e.fecha_inicio, e.fecha_fin, e.estado, 
                   e.analisis_ia, e.puntuacion_global,
                   p.nombre as plantilla, p.puesto,
                   c.nombre as candidato_nombre, c.id as candidato_id,
                   c.raw_data
            FROM entrevistas e
            JOIN plantillas_entrevista p ON e.plantilla_id = p.id
            JOIN candidates c ON e.candidato_id = c.id
            WHERE e.id = ?
        ''', (entrevista_id,))
        
        row = cursor.fetchone()
        if not row:
            return jsonify({"success": False, "error": "Entrevista no encontrada"}), 404
        
        # 2. Obtener todas las respuestas
        cursor.execute('''
            SELECT r.pregunta_texto, r.respuesta_texto, r.tiempo_respuesta,
                   r.respuesta_video_path, r.analisis_pregunta, r.puntuacion_pregunta,
                   r.id
            FROM respuestas_entrevista r
            WHERE r.entrevista_id = ?
            ORDER BY r.id
        ''', (entrevista_id,))
        
        respuestas = []
        for r in cursor.fetchall():
            respuestas.append({
                "pregunta": r[0],
                "respuesta": r[1],
                "tiempo": r[2],
                "video": r[3],
                "analisis": json.loads(r[4]) if r[4] else None,
                "puntuacion": r[5],
                "id": r[6]
            })
        
        conn.close()
        
        # 3. Parsear datos del candidato
        candidato_data = json.loads(row[10]) if row[10] else {}
        
        # 4. Si no hay análisis IA, generarlo ahora
        analisis = None
        if row[4]:
            analisis = json.loads(row[4])
        else:
            # Generar análisis automático
            prompt = f"""
Eres un headhunter experto con 20 años de experiencia. Analiza esta entrevista completa:

Candidato: {row[8]}
Puesto: {row[7] if row[7] else 'No especificado'}

RESPUESTAS:
{chr(10).join([f"Pregunta: {r['pregunta']}\nRespuesta: {r['respuesta']}\n" for r in respuestas])}

Proporciona un análisis PROFESIONAL y DETALLADO en JSON con:
{{
  "impresion_general": "texto detallado de impresión general",
  "fortalezas_destacadas": ["lista de fortalezas clave observadas"],
  "areas_oportunidad": ["lista de áreas de mejora"],
  "analisis_por_pregunta": [
    {{
      "pregunta": "texto de la pregunta",
      "evaluacion": "análisis de la respuesta",
      "puntuacion": 0-10,
      "aspectos_positivos": ["lista"],
      "aspectos_mejorar": ["lista"]
    }}
  ],
  "coherencia_perfil": "análisis de coherencia con el CV",
  "recomendacion_final": "contratar / considerar / no_contratar",
  "puntuacion_global": 0-100,
  "nivel_ingles": "avanzado/intermedio/básico/no detectable",
  "habilidades_blandas": ["lista"],
  "habilidades_tecnicas": ["lista"],
  "observaciones_especiales": "cualquier observación relevante"
}}
"""
            try:
                response = openai_client.chat.completions.create(
                    model="gpt-4o-mini",
                    messages=[{"role": "user", "content": prompt}],
                    temperature=0.3,
                    max_tokens=1500
                )
                analisis = safe_json_parse(response.choices[0].message.content)
                
                # Guardar análisis en BD
                conn2 = sqlite3.connect(DB_PATH)
                cur2 = conn2.cursor()
                cur2.execute('''
                    UPDATE entrevistas 
                    SET analisis_ia = ?, puntuacion_global = ?
                    WHERE id = ?
                ''', (json.dumps(analisis, ensure_ascii=False), 
                      analisis.get('puntuacion_global', 0), entrevista_id))
                conn2.commit()
                conn2.close()
            except Exception as e:
                print(f"❌ Error generando análisis: {e}")
                analisis = None
        
        return jsonify({
            "success": True,
            "entrevista": {
                "id": row[0],
                "fecha": row[1],
                "fecha_fin": row[2],
                "estado": row[3],
                "analisis": analisis,
                "puntuacion": row[5],
                "plantilla": row[6],
                "puesto": row[7],
                "candidato_nombre": row[8],
                "candidato_id": row[9],
                "candidato_data": candidato_data
            },
            "respuestas": respuestas
        })
        
    except Exception as e:
        print(f"❌ Error: {e}")
        import traceback
        traceback.print_exc()
        return jsonify({"success": False, "error": str(e)}), 500                       


