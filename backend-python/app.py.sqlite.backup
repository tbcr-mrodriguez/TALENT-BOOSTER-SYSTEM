@app.route("/api/analyze", methods=["POST"])
def api_analyze():
    try:
        print("="*50)
        print("📥 PYTHON: Recibida petición de análisis")
        
        # Inicializar base de datos
        init_database()
        
        # Obtener archivos
        files = request.files.getlist("files")
        print(f"📁 Archivos recibidos: {len(files)}")
        
        if not files:
            print("❌ No se recibieron archivos")
            return jsonify({"success": False, "error": "No se recibieron archivos"}), 400
        
        model = request.form.get("model", "gpt")
        print(f"🤖 Modelo: {model}")
        
        results = []
        
        for file in files:
            filename = file.filename
            print(f"📄 Procesando: {filename}")
            
            # Guardar archivo
            path = os.path.join(UPLOAD_FOLDER, filename)
            file.save(path)
            print(f"✅ Archivo guardado en: {path}")
            
            # Extraer texto
            text = extract_text(path)
            print(f"📝 Texto extraído: {len(text)} caracteres")
            
            if not text or len(text) < 50:
                print(f"⚠️ Texto muy corto o vacío para {filename}")
                continue
            
            # Analizar con IA
            print(f"🤖 Analizando con {model}...")
            data = analyze_cv(text, model)
            print(f"✅ Análisis completado")
            
            data = normalize_lists(data)
            data = score_candidate(data)
            data["archivo"] = filename
            data["fecha_analisis"] = datetime.now().isoformat()
            
            # Guardar en BD
            candidate_id = save_candidate_to_db(data)
            print(f"✅ Candidato guardado con ID: {candidate_id}")
            
            results.append(data)
        
        print(f"📊 Total procesados: {len(results)}")
        print("="*50)
        
        # ⚠️ IMPORTANTE: Siempre devolver algo
        return jsonify({"success": True, "data": results})
        
    except Exception as e:
        print(f"❌ ERROR en Python: {e}")
        import traceback
        traceback.print_exc()
        # ⚠️ IMPORTANTE: Devolver error en caso de excepción
        return jsonify({"success": False, "error": str(e)}), 500

@app.route("/api/search", methods=["GET"])
