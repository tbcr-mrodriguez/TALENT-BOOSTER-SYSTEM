@app.route("/api/entrevista/iniciar", methods=["POST"])
def iniciar_entrevista():
    """Crea una nueva entrevista y genera token para el candidato"""
    try:
        data = request.json
        candidato_id = data.get('candidato_id')
        plantilla_id = data.get('plantilla_id')
        
        token = secrets.token_urlsafe(32)
        base_url = request.host_url.rstrip('/')
        enlace = f"{base_url}/entrevista-candidato.html?token={token}"
        
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        cursor.execute('''
            INSERT INTO entrevistas 
            (candidato_id, plantilla_id, token_acceso, fecha_inicio, estado, enlace_compartido)
            VALUES (?, ?, ?, ?, ?, ?)
        ''', (candidato_id, plantilla_id, token, datetime.now(), 'pendiente', enlace))
        
        entrevista_id = cursor.lastrowid
        conn.commit()
        conn.close()
        
        return jsonify({
            "success": True,
            "entrevista_id": entrevista_id,
            "enlace": enlace,
            "token": token
        })
        
    except Exception as e:
        return jsonify({"success": False, "error": str(e)}), 500

@app.route("/api/entrevista/candidato/<token>", methods=["GET"])
def obtener_entrevista_candidato(token):
    """El candidato accede con su token y obtiene las preguntas"""
    try:
        conn = sqlite3.connect(DB_PATH)
        cursor = conn.cursor()
        
        # 1. Obtener la entrevista
        cursor.execute('''
            SELECT e.id, e.estado, e.fecha_inicio, e.plantilla_id,
                   c.nombre, c.id as candidato_id
            FROM entrevistas e
            JOIN candidates c ON e.candidato_id = c.id
            WHERE e.token_acceso = ?
        ''', (token,))
        
        row = cursor.fetchone()
        if not row:
            conn.close()
            return jsonify({"success": False, "error": "Entrevista no encontrada"}), 404
        
        entrevista_id = row[0]
        estado = row[1]
        plantilla_id = row[3]
        candidato_nombre = row[4]
        candidato_id = row[5]
        
        # 2. Verificar estado
        if estado != 'pendiente':
            conn.close()
            return jsonify({
                "success": False, 
                "error": f"Esta entrevista ya fue {estado}. Estado actual: {estado}"
            }), 400
        
        # 3. Obtener nombre de la plantilla
        cursor.execute('SELECT nombre, puesto FROM plantillas_entrevista WHERE id = ?', (plantilla_id,))
        plantilla_info = cursor.fetchone()
        plantilla_nombre = plantilla_info[0] if plantilla_info else 'Entrevista'
        plantilla_puesto = plantilla_info[1] if plantilla_info else None
        
        # 4. Obtener preguntas de la plantilla
        cursor.execute('''
            SELECT id, pregunta, categoria, tiempo_maximo
            FROM banco_preguntas
            WHERE plantilla_id = ?
            ORDER BY orden
        ''', (plantilla_id,))
        
        preguntas_rows = cursor.fetchall()
        preguntas = []
        for row in preguntas_rows:
            preguntas.append({
                "id": row[0],
                "pregunta": row[1],
                "categoria": row[2] or 'general',
                "tiempo_maximo": row[3] or 120
            })
        
        print(f"📋 Preguntas encontradas para plantilla {plantilla_id}: {len(preguntas)}")
        
        # 5. Verificar que hay preguntas
        if len(preguntas) == 0:
            conn.close()
            print(f"⚠️ ¡La plantilla '{plantilla_nombre}' (ID: {plantilla_id}) NO TIENE PREGUNTAS!")
            return jsonify({
                "success": False,
                "error": f"La plantilla '{plantilla_nombre}' no tiene preguntas configuradas"
            }), 400
        
        # 6. Actualizar estado a 'en_progreso'
        cursor.execute('''
            UPDATE entrevistas SET estado = 'en_progreso' WHERE id = ?
        ''', (entrevista_id,))
        
        conn.commit()
        conn.close()
        
        return jsonify({
            "success": True,
            "entrevista": {
                "id": entrevista_id,
                "candidato_nombre": candidato_nombre,
                "candidato_id": candidato_id,
                "plantilla_nombre": plantilla_nombre,
                "puesto": plantilla_puesto,
                "preguntas": preguntas,
                "total_preguntas": len(preguntas)
            }
        })
        
    except Exception as e:
        print(f"❌ Error en obtener_entrevista_candidato: {e}")
        import traceback
        traceback.print_exc()
        # Asegurar que la conexión se cierre en caso de error
        try:
            conn.close()
        except:
            pass
        return jsonify({"success": False, "error": str(e)}), 500
    
