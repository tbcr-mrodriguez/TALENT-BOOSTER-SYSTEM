@app.route("/search", methods=["GET"])
def search():
    try:
        skills = request.args.getlist('skills[]')
        sector = request.args.get('sector')
        min_score = request.args.get('min_score', type=int)
        
        results = search_candidates_db(
            skills=skills,
            sector=sector,
            min_score=min_score
        )
        
        return jsonify({
