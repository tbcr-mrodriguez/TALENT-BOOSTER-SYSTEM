@app.route("/search-embedding", methods=["POST"])
def search_embedding():
    """Búsqueda semántica con embeddings"""
    try:
        data = request.json
        query = data.get('query', '')
        limite = data.get('limite', 20)
        
        if not query:
            return jsonify({"success": False, "error": "Texto de búsqueda vacío"})
        
        candidatos = buscar_por_embedding(query, limite)
        
        return jsonify({
            "success": True,
            "data": candidatos,
            "count": len(candidatos),
            "metodo": "embeddings"
        })
        
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

@app.route("/ranking-ia", methods=["POST"])
def ranking_ia():
    """Ranking fino con ChatGPT sobre resultados de embeddings"""
    try:
        data = request.json
        candidatos = data.get('candidatos', [])
        query = data.get('query', '')
        model = data.get('model', 'gpt')
        
        if not candidatos or not query:
            return jsonify({"success": False, "error": "Faltan datos"})
        
        resultado_ranking = ranking_con_chatgpt(candidatos, query, model)
        
        if resultado_ranking:
            # Reordenar candidatos según ranking
            ranking_ids = resultado_ranking.get('ranking', [])
            candidatos_ordenados = []
            for pos in ranking_ids:
                if 1 <= pos <= len(candidatos):
                    candidatos_ordenados.append(candidatos[pos-1])
            
            return jsonify({
                "success": True,
                "data": candidatos_ordenados,
                "explicacion": resultado_ranking.get('mejor_explicacion', ''),
                "analisis": resultado_ranking.get('analisis', '')
            })
        else:
            return jsonify({"success": False, "error": "Error en ranking"})
        
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

@app.route("/reindex-embeddings", methods=["POST"])
def reindex_embeddings():
    """Reconstruye todos los embeddings (útil después de migración)"""
    try:
        candidatos = load_all_candidates_from_db()
        exitos = 0
        errores = 0
        
        for c in candidatos:
            if generar_embedding_candidato(c, c['id']):
                exitos += 1
            else:
                errores += 1
        
        return jsonify({
            "success": True,
            "message": f"Reindexación completada: {exitos} éxitos, {errores} errores"
        })
        
    except Exception as e:
        return jsonify({"success": False, "error": str(e)})

@app.route("/export", methods=["POST"])
def export():
    data = request.json
    df = pd.DataFrame(data)
    output = BytesIO()
    with pd.ExcelWriter(output, engine='xlsxwriter') as writer:
        df.to_excel(writer, index=False)
    output.seek(0)
    return send_file(
        output,
        as_attachment=True,
        download_name="talent_pipeline.xlsx",
        mimetype="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
    )

@app.route("/view-cv/<path:filename>", methods=["GET"])
def view_cv(filename):
    try:
        from urllib.parse import unquote
        filename = unquote(filename)
        file_path = os.path.join(UPLOAD_FOLDER, filename)
        
        print(f"🔍 Buscando archivo: {file_path}")
        
        if not os.path.exists(file_path):
            return f"Archivo no encontrado: {filename}", 404
        
        return send_file(file_path)
        
    except Exception as e:
        return f"Error: {str(e)}", 500

